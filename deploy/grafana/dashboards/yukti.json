{
  "title": "Yukti Trading Dashboard",
  "uid": "yukti-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agent Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "yukti_agent_halted", "legendFormat": "Halted" }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red",   "value": 1 }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Today P&L %",
      "type": "stat",
      "gridPos": { "x": 3, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "yukti_daily_pnl_pct", "legendFormat": "P&L %" }],
      "options": {
        "colorMode": "value",
        "thresholds": {
          "steps": [
            { "color": "red",   "value": -2 },
            { "color": "yellow","value": 0  },
            { "color": "green", "value": 1  }
          ]
        },
        "unit": "percent"
      }
    },
    {
      "id": 3,
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "x": 7, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "yukti_trades_open", "legendFormat": "Open" }]
    },
    {
      "id": 4,
      "title": "Win Rate (last 10)",
      "type": "gauge",
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "yukti_win_rate_last_10 * 100", "legendFormat": "Win %" }],
      "options": {
        "minValue": 0,
        "maxValue": 100,
        "thresholds": {
          "steps": [
            { "color": "red",    "value": 0  },
            { "color": "yellow", "value": 40 },
            { "color": "green",  "value": 55 }
          ]
        },
        "unit": "percent"
      }
    },
    {
      "id": 5,
      "title": "Account Value (INR)",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "yukti_account_value_inr", "legendFormat": "Account" }],
      "options": { "unit": "currencyINR" }
    },
    {
      "id": 6,
      "title": "Trades over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(yukti_trades_total{outcome='win'}[5m])",  "legendFormat": "Wins/s" },
        { "expr": "rate(yukti_trades_total{outcome='loss'}[5m])", "legendFormat": "Losses/s" }
      ]
    },
    {
      "id": 7,
      "title": "Claude latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.5,  rate(yukti_claude_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(yukti_claude_latency_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "options": { "unit": "s" }
    },
    {
      "id": 8,
      "title": "Skip reasons breakdown",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "expr": "increase(yukti_signals_skipped_total[1h])", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 9,
      "title": "Claude API cost (USD, cumulative)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "yukti_claude_cost_usd_total", "legendFormat": "Total cost" }],
      "options": { "unit": "currencyUSD" }
    },
    {
      "id": 10,
      "title": "Consecutive losses",
      "type": "stat",
      "gridPos": { "x": 14, "y": 12, "w": 4, "h": 4 },
      "targets": [{ "expr": "yukti_consecutive_losses", "legendFormat": "Losses" }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green",  "value": 0 },
            { "color": "yellow", "value": 2 },
            { "color": "red",    "value": 3 }
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "DhanHQ API errors",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 12, "h": 6 },
      "targets": [
        { "expr": "rate(yukti_dhan_requests_total{status='error'}[5m])", "legendFormat": "Errors/s {{endpoint}}" }
      ]
    }
  ]
}
